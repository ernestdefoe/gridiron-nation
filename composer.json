{
    "name": "ernestdefoe/fbsfb",
    "description": "GridIron Nation — College football fan forum theme for Flarum 2. Crimson & DM Sans, Avocado-style organic radius, dark mode, live score widget.",
    "type": "flarum-extension",
    "keywords": ["flarum", "theme", "college football", "gridiron", "sports"],
    "homepage": "https://github.com/ernestdefoe/fbsfb",
    "license": "MIT",
    "authors": [
        {
            "name": "Ernestdefoe",
            "email": "ernestdefoe@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "flarum/core": "^2.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "suggest": {
        "ernestdefoe/recruiting": "Powers the Top Recruits sidebar widget with live CollegeFootballData.com data + On3 photo headshots. Without this extension installed, the widget is hidden."
    },
    "autoload": {
        "psr-4": {
            "Ernestdefoe\\Fbsfb\\": "src/"
        }
    },
    "extra": {
        "flarum-extension": {
            "title": "GridIron Nation",
            "category": "theme",
            "icon": {
                "name": "fas fa-football",
                "backgroundColor": "#B22222",
                "color": "#fff"
            }
        }
    },
    "config": {
        "sort-packages": true
    }
}
